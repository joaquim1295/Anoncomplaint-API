{
  "expo": {
    "name": "SmartComplaint Mobile",
    "slug": "smart-complaint-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#070A12"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.smartcomplaint.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.smartcomplaint.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
