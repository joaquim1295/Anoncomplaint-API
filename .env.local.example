# ==========================================
# SmartComplaint v4.0 - Variáveis de Ambiente
# Instruções: 
# 1. Copie este ficheiro para .env.local
# 2. NÃO publique o .env.local no GitHub
# ==========================================

# === Database (MongoDB) ===
# String de conexão do MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smart_complaint
MONGODB_DB=smart_complaint_db

# === Segurança & Autenticação ===
# Chave forte para JWT (mínimo 32 caracteres)
JWT_SECRET=gerar_uma_string_aleatoria_com_openssl_rand_base64_32
# URL pública do site (metadata, sitemap, emails com links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Pepper estático para hashing de passwords (NUNCA ALTERAR)
PASSWORD_PEPPER=pepper_secreto_da_plataforma

# === Real-time (Pusher Channels) ===
# Credenciais obtidas em dashboard.pusher.com
PUSHER_APP_ID=seu_app_id
PUSHER_KEY=sua_key
PUSHER_SECRET=seu_secret
PUSHER_CLUSTER=eu

# Variáveis Públicas do Pusher (necessárias para o Cliente/Browser)
NEXT_PUBLIC_PUSHER_KEY=sua_key
NEXT_PUBLIC_PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_APP_KEY=sua_key
NEXT_PUBLIC_PUSHER_APP_CLUSTER=eu

# Compat aliases (se usar APP_KEY no dashboard/config)
PUSHER_APP_KEY=sua_key
PUSHER_APP_CLUSTER=eu

# === Inteligência Artificial (Vercel AI SDK / Groq) ===
# Chave para moderação e análise de sentimento
GROQ_API_KEY=gsk_sua_chave_aqui

# === Sistema de Emails (Resend) ===
# Chave para notificações de novas queixas e respostas
RESEND_API_KEY=re_sua_chave_aqui

# === Armazenamento de imagens (Cloudinary) ===
# Opcional A: URL no formato EXACTO (não uses https:// aqui — o SDK Node rejeita)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Opcional B: variáveis separadas (recomendado se copiaste um URL https do dashboard por engano)
# CLOUDINARY_CLOUD_NAME=seu_cloud_name
# CLOUDINARY_API_KEY=sua_api_key
# CLOUDINARY_API_SECRET=o_seu_api_secret
# Se definires B e tiveres um CLOUDINARY_URL=https://... inválido, remove o https ou deixa só B (a app ignora URLs inválidos ao usar B).
# Sem Cloudinary: anexos e avatar continuam em base64/URL externa (menos ideal em produção).

# === Rate limiting (Upstash Redis) ===
# https://console.upstash.com — cria uma base Redis REST
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXX...
# Sem Upstash: os limites por IP não são aplicados (apenas dev).

# === Rate limit / proxy ===
# Só defina TRUST_X_FORWARDED_FOR=1 atrás de um proxy que *substitui* X-Forwarded-For (ex.: Vercel, Cloudflare).
# Se estiver exposto directamente à Internet, deixe em branco para não permitir falsificar o IP no rate limit.
# TRUST_X_FORWARDED_FOR=1

# === Observabilidade (Sentry) ===
# Opcional: npx @sentry/wizard@latest -i nextjs (instala @sentry/nextjs, client/server configs e CSP).
# SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN conforme o wizard indicar.

# === God mode (apenas demo / ambientes controlados) ===
# ALLOW_GOD_MODE=1 — permite POST /api/v1/admin/god-mode/force-approve em produção
# ALLOW_GOD_MODE_RESET=1 — permite reset de demo em produção

