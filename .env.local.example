# ==========================================
# AnonComplaint - Variáveis de Ambiente
# Copie este ficheiro para .env.local e preencha os valores
# ==========================================

# === Database (MongoDB) ===
# A string de conexão do seu cluster MongoDB (Atlas ou Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.exemplo.mongodb.net/?retryWrites=true&w=majority
# O nome exato da base de dados que a aplicação vai instanciar
MONGODB_DB=anon_complaint_db

# === Segurança & Autenticação ===
# Chave secreta para assinar e validar os tokens JWT (Gere uma string forte de 32+ caracteres)
JWT_SECRET=substituir_por_uma_string_aleatoria_muito_longa_e_segura
# O "Pepper" global anexado às senhas antes do hash (ATENÇÃO: Nunca altere isto em produção, ou perderá o acesso às contas)
PASSWORD_PEPPER=substituir_por_um_pepper_estatico_e_secreto

# === Integrações de Inteligência Artificial ===
# Chave da API do Groq para o AI Insights (Gere em: https://console.groq.com/)
GROQ_API_KEY=gsk_sua_chave_da_api_groq_aqui

# === Sistema de Notificações & Emails ===
# Chave da API do Resend para enviar os alertas transacionais (Gere em: https://resend.com/)
RESEND_API_KEY=re_sua_chave_da_api_resend_aqui